FURNACE_DATABASE_URL=sqlite+aiosqlite:///./furnace.db
FURNACE_PROVISIONER=fake
FURNACE_ARTIFACTS_DIR=./artifacts
FURNACE_SESSION_STEP_DELAY_SECONDS=0.05
FURNACE_WEB_ORIGIN=http://localhost:3000
FURNACE_FAKE_QUEUE_ACQUIRE=false
FURNACE_FAKE_MAX_SLOTS=4
FURNACE_POOL_ESTIMATED_SESSION_SECONDS=30
FURNACE_POOL_SCALE_UP_THRESHOLD=1
FURNACE_AUTH_JWT_SECRET=dev-only-change-me
FURNACE_AUTH_ACCESS_TOKEN_TTL_SECONDS=604800
## Local Postgres example for migrations/dev.
# FURNACE_DATABASE_URL=postgresql+asyncpg://furnace:furnace@localhost:5432/furnace
# FURNACE_RUN_MIGRATIONS_ON_STARTUP=true
# FURNACE_AUTO_CREATE_SCHEMA=false
# GitHub App Setup URL should be https://<host>/v1/github/setup
# Dev-only example; replace before production use.
FURNACE_MASTER_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
